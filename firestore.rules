rules_version = '2';
// Nege Systems — Firestore аюулгүй байдлын дүрмүүд.
// Roles болон collection-уудын эрхийн тайлбар: docs/FIRESTORE_ROLES.md

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Туслах функцууд ─────────────────────────────────────────────────
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.role in ['company_super_admin', 'admin', 'super_admin'];
    }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Multi-tenant: Companies ───────────────────────────────────────
    function getCompanyId() {
      return request.auth.token.companyId;
    }

    function belongsToCompany(companyId) {
      return isSignedIn() && request.auth.token.companyId == companyId;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'super_admin';
    }

    function isCompanyAdmin(companyId) {
      return belongsToCompany(companyId) && request.auth.token.role in ['company_super_admin', 'admin', 'super_admin'];
    }

    match /companies/{companyId} {
      allow read: if belongsToCompany(companyId) || isSuperAdmin();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.name_lower is string
        && request.resource.data.name_lower == request.resource.data.name.lower();
      allow update: if isCompanyAdmin(companyId) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      // Tenant-scoped subcollections
      match /employees/{employeeId} {
        allow read: if belongsToCompany(companyId);
        allow create: if isCompanyAdmin(companyId);
        allow update: if isCompanyAdmin(companyId) || (
          belongsToCompany(companyId) && isOwner(employeeId) &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'questionnaireLocked'])
        );
        allow delete: if isCompanyAdmin(companyId);
      }

      match /departments/{departmentId} {
        allow read: if belongsToCompany(companyId);
        allow write: if isCompanyAdmin(companyId);
      }

      match /positions/{positionId} {
        allow read: if belongsToCompany(companyId);
        allow write: if isCompanyAdmin(companyId);
      }

      match /projects/{projectId} {
        allow read: if belongsToCompany(companyId);
        allow create: if belongsToCompany(companyId);
        allow update: if belongsToCompany(companyId) && (
          isCompanyAdmin(companyId) ||
          request.auth.uid == resource.data.ownerId ||
          request.auth.uid == resource.data.createdBy
        );
        allow delete: if isCompanyAdmin(companyId) || (
          belongsToCompany(companyId) && request.auth.uid == resource.data.createdBy
        );

        match /tasks/{taskId} {
          allow read: if belongsToCompany(companyId);
          allow create: if belongsToCompany(companyId);
          allow update: if belongsToCompany(companyId) && (
            isCompanyAdmin(companyId) ||
            request.auth.uid == resource.data.ownerId ||
            request.auth.uid in resource.data.get('assigneeIds', [])
          );
          allow delete: if isCompanyAdmin(companyId);
        }

        match /messages/{messageId} {
          allow read: if belongsToCompany(companyId);
          allow create: if belongsToCompany(companyId);
          allow update: if belongsToCompany(companyId) && request.auth.uid == resource.data.senderId;
          allow delete: if isCompanyAdmin(companyId) || (
            belongsToCompany(companyId) && request.auth.uid == resource.data.senderId
          );
        }
      }

      // Surveys (tenant-scoped)
      match /surveys/{surveyId} {
        allow read: if belongsToCompany(companyId);
        allow create: if belongsToCompany(companyId);
        allow update: if belongsToCompany(companyId);
        allow delete: if isCompanyAdmin(companyId);

        match /questions/{questionId} {
          allow read: if belongsToCompany(companyId);
          allow write: if belongsToCompany(companyId);
        }

        match /responses/{responseId} {
          allow read: if isCompanyAdmin(companyId);
          allow create: if belongsToCompany(companyId);
          allow delete: if isCompanyAdmin(companyId);
        }
      }

      // Company settings (branding, profile, etc.)
      match /company/{allPaths=**} {
        allow read: if belongsToCompany(companyId);
        allow write: if isCompanyAdmin(companyId);
      }

      match /workCalendars/{calendarId} {
        allow read: if belongsToCompany(companyId);
        allow create: if isCompanyAdmin(companyId);
        allow update: if isCompanyAdmin(companyId);
        allow delete: if isCompanyAdmin(companyId);
      }

      // Evaluation requests — explicit rules so non-admin employees can create/update
      match /evaluation_requests/{requestId} {
        allow read: if belongsToCompany(companyId);
        allow create: if belongsToCompany(companyId)
          && request.resource.data.requestedBy == request.auth.uid
          && request.resource.data.status == 'pending';
        allow update: if belongsToCompany(companyId) && (
          isCompanyAdmin(companyId) ||
          request.auth.uid == resource.data.get('assignedTo', '') ||
          request.auth.uid == resource.data.get('requestedBy', '')
        );
        allow delete: if isCompanyAdmin(companyId);
      }

      // Catch-all for other tenant subcollections (single level)
      match /{subcollection}/{docId} {
        allow read: if isCompanyAdmin(companyId);
        allow write: if isCompanyAdmin(companyId);
      }

      // Catch-all recursive for deeply nested paths
      match /{subcollection}/{allPaths=**} {
        allow read: if isCompanyAdmin(companyId);
        allow write: if isCompanyAdmin(companyId);
      }
    }

    // ─── Platform-level collections (Super Admin only) ─────────────────
    match /platform/{docId} {
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    // Deletion audit log subcollection
    match /platform/{docId}/{subcollection}/{entryId} {
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isSuperAdmin() || (isSignedIn() && resource.data.companyId == request.auth.token.companyId);
      allow write: if isSuperAdmin();
    }

    match /system/signup_config {
      allow read: if true;
      allow create: if !exists(/databases/$(database)/documents/system/signup_config);
      allow update, delete: if isAdmin();
    }

    // All employee data is now tenant-scoped under companies/{companyId}/employees/
    // Top-level employees collection is deprecated — no reads or writes allowed.
    
    // company, companyPolicies, departments, positions, onboardingPrograms,
    // newHires, organization_actions, settings, companyHistory, company_profile,
    // attendance → now tenant-scoped under companies/{companyId}/
    // Handled by catch-all rules in match /companies/{companyId}/{subcollection}/{...}

    // The following comment is a special instruction for the backend to create an index.
    // Please do not modify or remove it.
    // FIRESTORE_INDEX: COLLECTION_GROUP(timeOffRequests) ASC(status)

    // timeOffRequests — handled by tenant-scoped catch-all rules
    // (companies/{companyId}/{subcollection}/{allPaths=**})

    // vacationRequests — handled by tenant-scoped catch-all rules
    // (companies/{companyId}/{subcollection}/{allPaths=**})
    
    
    // er_document_types, er_templates, er_workflows → now tenant-scoped
    // Handled by catch-all rules in match /companies/{companyId}/{subcollection}/{...}

    // ER процессын баримтын төрлүүд (employment-relations settings)
    match /er_process_document_types/{typeId} {
      allow read: if isSignedIn();
      // Admins manage settings. Signed-in users may only bump the numbering counter
      // in a tightly validated way (so document creation can allocate numbers).
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && (
        // Only allow updating counter-related fields
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'currentNumber',
          'lastNumberYear',
          'lastNumberMonth',
          'lastNumberDay',
          'updatedAt'
        ]) &&
        // Ensure numeric fields are numbers
        (request.resource.data.currentNumber is int || request.resource.data.currentNumber is number) &&
        (request.resource.data.lastNumberYear is int || request.resource.data.lastNumberYear is number) &&
        (request.resource.data.lastNumberMonth is int || request.resource.data.lastNumberMonth is number) &&
        (request.resource.data.lastNumberDay is int || request.resource.data.lastNumberDay is number) &&
        // Ensure date parts match request.time
        request.resource.data.lastNumberYear == request.time.year &&
        request.resource.data.lastNumberMonth == request.time.month &&
        request.resource.data.lastNumberDay == request.time.day &&
        // Ensure counter increments by 1 OR resets to startNumber based on resetPeriod
        (
          // Increment path
          request.resource.data.currentNumber == (resource.data.currentNumber + 1)
          ||
          // Reset path (yearly/monthly/daily) to startNumber
          (
            request.resource.data.currentNumber ==
              (resource.data.numberingConfig.startNumber is int ? resource.data.numberingConfig.startNumber : 1)
            &&
            (
              resource.data.numberingConfig.resetPeriod == 'yearly' && resource.data.lastNumberYear != request.time.year
              ||
              resource.data.numberingConfig.resetPeriod == 'monthly' && (
                resource.data.lastNumberYear != request.time.year || resource.data.lastNumberMonth != request.time.month
              )
              ||
              resource.data.numberingConfig.resetPeriod == 'daily' && (
                resource.data.lastNumberYear != request.time.year ||
                resource.data.lastNumberMonth != request.time.month ||
                resource.data.lastNumberDay != request.time.day
              )
            )
          )
        )
      ));
    }

    // Documents - Complex rules based on status and role
    match /er_documents/{documentId} {
      // Read access:
      // - Creator can always read their own documents
      // - Reviewers can read documents they need to review
      // - Admins can read all
      allow read: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.creatorId ||
        request.auth.uid == resource.data.employeeId ||
        request.auth.uid in resource.data.get('reviewers', []) ||
        request.auth.token.get('positionId', '') in resource.data.get('reviewers', [])
      );
      
      // Create: signed-in user, must be the listed creator, initial status DRAFT
      allow create: if isSignedIn()
        && request.resource.data.creatorId == request.auth.uid
        && request.resource.data.status == 'DRAFT';
      
      // Update access:
      // - Creator can update their own DRAFT documents
      // - Reviewers can update approvalStatus when document is IN_REVIEW
      // - Creator can finalize approval when status is REVIEWED
      // - Admins can update anything
      allow update: if isSignedIn() && (
        isAdmin() ||
        // Creator updating their own draft
        (request.auth.uid == resource.data.creatorId && resource.data.status == 'DRAFT') ||
        // Creator finalizing approval when all reviewers approved
        (request.auth.uid == resource.data.creatorId && resource.data.status == 'REVIEWED' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
        // Admin/reviewer/creator sending SIGNED doc to employee for acknowledgement
        (
          resource.data.status in ['SIGNED', 'APPROVED'] &&
          request.resource.data.status == 'SENT_TO_EMPLOYEE' &&
          (
            request.auth.uid == resource.data.creatorId ||
            request.auth.uid in resource.data.get('reviewers', []) ||
            request.auth.token.get('positionId', '') in resource.data.get('reviewers', [])
          ) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'employeeAckRequired',
            'employeeAckSentAt',
            'employeeAckSentBy',
            'updatedAt'
          ]) &&
          (request.resource.data.employeeAckRequired is bool) &&
          (request.resource.data.employeeAckSentAt is timestamp) &&
          (request.resource.data.employeeAckSentBy is string || request.resource.data.employeeAckSentBy == null)
        ) ||
        // Employee acknowledging SENT_TO_EMPLOYEE doc
        (
          resource.data.status == 'SENT_TO_EMPLOYEE' &&
          request.auth.uid == resource.data.employeeId &&
          request.resource.data.status == 'ACKNOWLEDGED' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'employeeAckAt',
            'employeeAckBy',
            'updatedAt'
          ]) &&
          (request.resource.data.employeeAckAt is timestamp) &&
          (request.resource.data.employeeAckBy == request.auth.uid)
        ) ||
        // Reviewer updating approval status
        (resource.data.status == 'IN_REVIEW' && 
         (request.auth.uid in resource.data.get('reviewers', []) ||
          request.auth.token.get('positionId', '') in resource.data.get('reviewers', [])) &&
         // Only allow updating specific fields
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['approvalStatus', 'status', 'updatedAt', 'rejectionReason']))
      );
      
      // Delete: Only creator can delete their own drafts, or admins
      allow delete: if isSignedIn() && (
        isAdmin() ||
        (request.auth.uid == resource.data.creatorId && resource.data.status == 'DRAFT')
      );
      // Activity Subcollection for Real-time History
      match /activity/{activityId} {
        // Read: Same as parent document (reviewers, creator, admin)
        allow read: if isSignedIn() && (
            isAdmin() ||
            request.auth.uid == get(/databases/$(database)/documents/er_documents/$(documentId)).data.creatorId ||
            request.auth.uid == get(/databases/$(database)/documents/er_documents/$(documentId)).data.employeeId ||
            request.auth.uid in get(/databases/$(database)/documents/er_documents/$(documentId)).data.reviewers ||
            request.auth.token.get('positionId', '') in get(/databases/$(database)/documents/er_documents/$(documentId)).data.reviewers
        );

        // Create: Reviewers, Creator, and target Employee (ack) can add logs
        allow create: if isSignedIn() && (
            isAdmin() ||
            request.auth.uid == get(/databases/$(database)/documents/er_documents/$(documentId)).data.creatorId ||
            request.auth.uid in get(/databases/$(database)/documents/er_documents/$(documentId)).data.reviewers ||
            request.auth.token.get('positionId', '') in get(/databases/$(database)/documents/er_documents/$(documentId)).data.reviewers
            ||
            (
              request.auth.uid == get(/databases/$(database)/documents/er_documents/$(documentId)).data.employeeId &&
              request.resource.data.keys().hasOnly(['type', 'actorId', 'content', 'createdAt']) &&
              request.resource.data.type == 'STATUS_CHANGE' &&
              request.resource.data.actorId == request.auth.uid
            )
        );
      }
    }
    
    // --- Recruitment Module Rules ---
    
    match /vacancies/{vacancyId} {
        allow read: if true; // Public read for job board (or use a cloud function for public access to be safer)
        allow write: if isAdmin();
    }
    
    match /candidates/{candidateId} {
        allow create: if true
          && request.resource.data.keys().hasAll(['firstName', 'lastName', 'email'])
          && request.resource.data.firstName is string
          && request.resource.data.firstName.size() > 0
          && request.resource.data.firstName.size() <= 200
          && request.resource.data.lastName is string
          && request.resource.data.lastName.size() > 0
          && request.resource.data.lastName.size() <= 200
          && request.resource.data.email is string
          && request.resource.data.email.size() > 0
          && request.resource.data.email.size() <= 320
          && request.resource.data.keys().size() <= 20;
        allow read, update, delete: if isAdmin();
    }
    
    match /applications/{applicationId} {
        allow create: if true
          && request.resource.data.keys().hasAll(['vacancyId', 'candidateId', 'status'])
          && request.resource.data.vacancyId is string
          && request.resource.data.vacancyId.size() > 0
          && request.resource.data.candidateId is string
          && request.resource.data.candidateId.size() > 0
          && request.resource.data.status is string
          && request.resource.data.keys().size() <= 25;
        allow read, update, delete: if isAdmin();
    }

    match /evaluation_requests/{requestId} {
        allow read: if isSignedIn() && (
          isAdmin() ||
          request.auth.uid == resource.data.get('requestedBy', '') ||
          request.auth.uid == resource.data.get('assignedTo', '')
        );
        allow create: if isSignedIn()
          && request.resource.data.requestedBy == request.auth.uid
          && request.resource.data.status == 'pending';
        allow update: if isSignedIn() && (
          isAdmin() ||
          request.auth.uid == resource.data.get('assignedTo', '') ||
          request.auth.uid == resource.data.get('requestedBy', '')
        );
        allow delete: if isAdmin();
    }
    
    match /interviews/{interviewId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }

    // Projects, tasks, messages → now tenant-scoped under companies/{companyId}/projects/
    // See match /companies/{companyId}/projects/ above for detailed rules

    // Surveys, survey_templates → now tenant-scoped under companies/{companyId}/surveys/
    // See match /companies/{companyId}/surveys/ above for detailed rules

  }
}
